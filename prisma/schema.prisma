datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// ─── AUTH (Better Auth) ───

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  avatar        String?  @db.Text
  bio           String?  @db.Text
  role          String   @default("USER") // USER | MODERATOR | ADMIN
  points        Int      @default(0)
  tier          String   @default("BRONZE") // BRONZE | SILVER | GOLD | DIAMOND
  locale        String   @default("vi")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Gamification stats
  lastLoginAt DateTime?
  loginStreak Int       @default(0)
  totalDeals  Int       @default(0)

  deals         Deal[]
  votes         Vote[]
  comments      Comment[]
  bookmarks     Bookmark[]
  dealAlerts    DealAlert[]
  notifications Notification[]
  userBadges    UserBadge[]
  followers     Follow[]         @relation("Followers")
  following     Follow[]         @relation("Following")
  collections   DealCollection[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  reports       Report[]
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String
  providerId   String // google | facebook | credential
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── DEALS (always start PENDING → mod approves → ACTIVE) ───

model Deal {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  description  String    @db.Text
  url          String    @db.Text
  image        String?   @db.Text
  price        Decimal?  @db.Decimal(12, 2)
  comparePrice Decimal?  @db.Decimal(12, 2)
  couponCode   String?
  merchant     String?
  temperature  Int       @default(0)
  status       String    @default("PENDING") // PENDING | ACTIVE | EXPIRED | SOLD_OUT | REJECTED
  type         String    @default("DEAL") // DEAL | VOUCHER | FREEBIE | DISCUSSION
  sponsored    Boolean   @default(false)
  affiliateUrl String?   @db.Text
  moderatedBy  String? // userId of moderator
  moderatedAt  DateTime?
  expiresAt    DateTime?
  viewCount    Int       @default(0)
  clickCount   Int       @default(0)
  blurHash     String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  votes        Vote[]
  comments     Comment[]
  bookmarks    Bookmark[]
  images       DealImage[]
  priceHistory PriceHistory[]
  views        DealView[]
  collections  DealCollectionItem[]

  @@index([status, type, temperature])
  @@index([categoryId])
  @@index([userId])
  @@fulltext([title, description])
}

// ─── HIERARCHICAL CATEGORIES (unlimited nesting via self-reference) ───

model Category {
  id       String     @id @default(cuid())
  nameVi   String
  nameEn   String
  slug     String     @unique
  icon     String?
  parentId String?
  depth    Int        @default(0)
  order    Int        @default(0)
  path     String?    @db.VarChar(500)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")

  deals      Deal[]
  dealAlerts DealAlert[]
}

// ── NEW MODELS FOR FUTURE PHASES ──

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // DEAL_APPROVED | DEAL_REJECTED | NEW_COMMENT | DEAL_ALERT | VOTE_MILESTONE | BADGE_EARNED
  title     String
  body      String   @db.Text
  link      String?
  read      Boolean  @default(false)
  channel   String   @default("in-app") // in-app | email | push
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

model PriceHistory {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  price     Decimal  @db.Decimal(12, 2)
  source    String   @default("user") // user | scraper
  createdAt DateTime @default(now())

  @@index([dealId, createdAt])
}

model Merchant {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logo        String?  @db.Text
  website     String?  @db.Text
  description String?  @db.Text
  rating      Decimal? @db.Decimal(3, 2)
  dealCount   Int      @default(0)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Badge {
  id          String @id @default(cuid())
  nameVi      String
  nameEn      String
  icon        String
  description String @db.Text
  condition   String
  points      Int    @default(0)

  userBadges UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model DealImage {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  blurHash  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([dealId, order])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model DealCollection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nameVi      String
  nameEn      String
  slug        String   @unique
  description String?  @db.Text
  public      Boolean  @default(true)
  createdAt   DateTime @default(now())

  items DealCollectionItem[]
}

model DealCollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  dealId       String
  order        Int      @default(0)
  addedAt      DateTime @default(now())

  collection DealCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  deal       Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([collectionId, dealId])
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String    @unique
  name      String
  scopes    String    @db.Text
  lastUsed  DateTime?
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
}

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  events    String   @db.Text
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DealView {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId    String?
  ip        String?
  userAgent String?  @db.Text
  referrer  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([dealId, createdAt])
  @@index([createdAt])
}

// ─── VOTING ───

model Vote {
  id        String   @id @default(cuid())
  value     Int // +1 (hot) or -1 (cold)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
}

// ─── COMMENTS (threaded via self-reference) ───

model Comment {
  id           String   @id @default(cuid())
  content      String   @db.Text
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId   String
  user     User      @relation(fields: [userId], references: [id])
  dealId   String?
  deal     Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  parentId String?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies  Comment[] @relation("Replies")

  reactions CommentReaction[]
}

model CommentReaction {
  id        String   @id @default(cuid())
  type      String   @default("HELPFUL") // HELPFUL | UNHELPFUL
  createdAt DateTime @default(now())

  userId    String
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// ─── USER FEATURES ───

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
}

model DealAlert {
  id             String   @id @default(cuid())
  keyword        String?
  merchant       String?
  categoryId     String?
  minTemperature Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  userId   String
  user     User      @relation(fields: [userId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
}

model Report {
  id         String   @id @default(cuid())
  targetType String // deal | comment | user
  targetId   String
  reason     String   @db.Text
  status     String   @default("PENDING") // PENDING | RESOLVED | DISMISSED
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// ─── MONETIZATION ───

model AffiliateConfig {
  id           String  @id @default(cuid())
  merchant     String  @unique
  affiliateTag String
  urlPattern   String  @db.Text // regex to match merchant URLs
  active       Boolean @default(true)
}

model AdPlacement {
  id          String    @id @default(cuid())
  slot        String // sidebar | in-feed | deal-detail
  title       String?
  imageUrl    String?   @db.Text
  targetUrl   String    @db.Text
  impressions Int       @default(0)
  clicks      Int       @default(0)
  active      Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
}

// ─── SITE THEME CONFIG (single-row table) ───

model SiteConfig {
  id          String   @id @default("default")
  layout      String   @default("modern") // modern | minimalist | mydealz | aliexpress | shopee
  scale       String   @default("md") // xs | sm | md | lg | xl
  colorScheme String   @default("default") // default | ocean | forest | tet | christmas | ...
  customCss   String?  @db.Text
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}
